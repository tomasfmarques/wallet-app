{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      // Mirrors the Vite `@engines` alias (docs/landing-spec.md A2). Only
      // loanEngine.ts and capitalGains.ts are meant to be imported this way.
      "@engines/*": ["../backend/src/lib/*"]
    },
    // Silence "baseUrl is deprecated" hard error. "5.0" is the only valid
    // value in TS 5.x — Render uses this version range.
    "ignoreDeprecations": "5.0",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "../backend/src/lib/loanEngine.ts",
    "../backend/src/lib/capitalGains.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
