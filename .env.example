# Root .env.example — copy to .env and fill in values

# ── Backend ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/wallet_app"

# Session secret (min 32 chars, random)
SESSION_SECRET="change-me-to-a-long-random-string"

# Finnhub API key (never expose to the browser)
FINNHUB_API_KEY=""

# Server port
PORT=4000

# ── Frontend (Vite) ───────────────────────────────────────
# Vite env vars must be prefixed with VITE_
VITE_API_URL="http://localhost:4000"

# Google Sign In Web Client ID (same value as backend's GOOGLE_CLIENT_ID).
# Frontend uses it to render the Google button; backend uses it to verify
# the ID token. Without this, the button stays hidden.
VITE_GOOGLE_CLIENT_ID=""
