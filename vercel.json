{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "crons": [
    { "path": "/api/cron/daily", "schedule": "0 6 * * *" }
  ],
  "redirects": [
    { "source": "/privacidade.html", "destination": "/privacidade", "permanent": true },
    { "source": "/eliminar-conta.html", "destination": "/eliminar-conta", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/simuladores", "destination": "/simuladores/index.html" },
    { "source": "/simuladores/irs-mais-valias", "destination": "/simuladores/irs-mais-valias/index.html" },
    { "source": "/simuladores/credito-habitacao", "destination": "/simuladores/credito-habitacao/index.html" },
    { "source": "/simuladores/amortizar-ou-investir", "destination": "/simuladores/amortizar-ou-investir/index.html" },
    { "source": "/simuladores/revisao-euribor", "destination": "/simuladores/revisao-euribor/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
