{
  "name": "wallet-app-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate:prod": "prisma generate --schema=prisma/schema.prod.prisma",
    "db:push:prod": "prisma db push --schema=prisma/schema.prod.prisma --accept-data-loss || (echo 'db push failed (Neon may be waking) — retrying in 12s...' && sleep 12 && prisma db push --schema=prisma/schema.prod.prisma --accept-data-loss)",
    "deploy:prep": "npm run db:generate:prod && npm run db:push:prod"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "@sentry/node": "^10.57.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^5.16.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
