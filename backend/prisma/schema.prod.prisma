// PRODUCTION schema — Postgres (Neon/Supabase/Render PG)
//
// IMPORTANT: keep this file in sync with schema.prisma manually. The only
// intended difference is the datasource provider. Everything else (models,
// fields, indexes, relations) must be identical to the dev schema.
//
// Used by:   npm run deploy:prep
// Generated client goes to ../node_modules/.prisma/client just like dev.

generator client {
  provider = "prisma-client-js"
  // "native" → Render (Debian); "rhel-openssl-3.0.x" → Vercel (AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  pinHash      String?  @map("pin_hash") // bcrypt hash of the 6-digit app-lock PIN
  emailVerifiedAt DateTime? @map("email_verified_at") // null = unverified; Google sign-in sets it implicitly
  isDemo       Boolean  @default(false) @map("is_demo") // throwaway demo account
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  loans             Loan[]
  portfolioAssets   PortfolioAsset[]
  portfolioSettings PortfolioSettings?
  incomes           Income[]
  expenses          Expense[]
  classificationRules ClassificationRule[]
  bankConnections   BankConnection[]
  brokerConnections BrokerConnection[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  webauthnCredentials WebAuthnCredential[]
  importedTxns      ImportedTxn[]
  pushSubscriptions PushSubscription[]
  notificationPreference NotificationPreference?
  householdMember   HouseholdMember?

  @@map("users")
}

// ── Modo Casal (household v1) — aggregate-only sharing, 2 members max.
// EXCLUDED from export/import (cross-user). See routes/household.ts.
model Household {
  id        String            @id @default(uuid())
  name      String            @default("A nossa casa")
  createdAt DateTime          @default(now()) @map("created_at")

  members HouseholdMember[]
  invites HouseholdInvite[]

  @@map("households")
}

model HouseholdMember {
  id          String   @id @default(uuid())
  householdId String   @map("household_id")
  userId      String   @unique @map("user_id")
  joinedAt    DateTime @default(now()) @map("joined_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("household_members")
}

model HouseholdInvite {
  id          String   @id @default(uuid())
  householdId String   @map("household_id")
  tokenHash   String   @unique @map("token_hash")
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("household_invites")
}

// One row per browser/device push registration. Device-bound (like passkeys)
// → EXCLUDED from export/import; dies with the user (cascade).
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// Per-user notification switches. User data → included in export/import.
model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique @map("user_id")
  pushPayment        Boolean @default(true)  @map("push_payment")
  pushEuribor        Boolean @default(true)  @map("push_euribor")
  pushImportReminder Boolean @default(true)  @map("push_import_reminder")
  emailMonthlyDigest Boolean @default(true)  @map("email_monthly_digest")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// Append-only audit trail of account deletions. Deliberately NOT linked to User
// (it must survive the user's deletion) and holds NO personal data — only a
// one-way sha256 of the email so a deletion can later be verified without
// retaining PII. NOT part of per-user export/import (it isn't user-scoped data).
model DeletionLog {
  id        String   @id @default(uuid())
  emailHash String   @map("email_hash")
  method    String   @default("self-service")
  note      String?
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("deletion_log")
}

model BrokerConnection {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  broker     String
  env        String    @default("live")
  keyEnc     String    @map("key_enc")
  secretEnc  String?   @map("secret_enc")
  accountCcy String?   @map("account_ccy")
  lastSyncAt DateTime? @map("last_sync_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, broker])
  @@index([userId])
  @@map("broker_connections")
}

// WebAuthn (passkey/biometric) credential for the PIN lock's biometric unlock.
// Device-bound — deliberately excluded from export/import backup.
model WebAuthnCredential {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  credentialId String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int      @default(0)
  transports   String?
  deviceName   String?  @map("device_name")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webauthn_credentials")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// Signup email-ownership proof. Mirrors PasswordResetToken (hashed token, one
// active per user, single-use) but with a longer window — a verification mail
// often gets opened the next day. EXCLUDED from export/import: a security
// artifact, not portable user data (same rule as password reset tokens).
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model BankConnection {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  requisitionId   String   @unique @map("requisition_id")
  institutionId   String   @map("institution_id")
  institutionName String   @map("institution_name")
  logo            String?
  status          String   @default("created")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_connections")
}

model ClassificationRule {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  matchKey  String   @map("match_key")
  kind      String
  type      String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchKey])
  @@index([userId])
  @@map("classification_rules")
}

// ── Budget ───────────────────────────────────────────────────────
model Income {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  amount    Float
  frequency String   @default("monthly")
  type      String   @default("fixed")
  category  String?
  active    Boolean  @default(true)
  pending   Boolean  @default(false)
  dayOfMonth Int?    @map("day_of_month")
  source    String?
  matchHint String?  @map("match_hint")
  startYm   String?  @map("start_ym")
  endYm     String?  @map("end_ym")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("incomes")
}

model Expense {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  amount      Float
  frequency   String   @default("monthly")
  type        String
  category    String?
  dayOfMonth  Int?     @map("day_of_month")
  active      Boolean  @default(true)
  pending     Boolean  @default(false)
  source      String?
  loanId      String?  @map("loan_id") // soft link to a Loan; budget syncs amount from its prestação
  matchHint   String?  @map("match_hint") // bank-statement description → matches imports to this plan row
  startYm     String?  @map("start_ym")
  endYm       String?  @map("end_ym")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@map("expenses")
}

// ── Loan ─────────────────────────────────────────────────────────

model Loan {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  name        String @default("Crédito")
  capital     Float
  prazoMeses  Int    @map("prazo_meses")
  tanFixa     Float  @map("tan_fixa")
  mesesFixos  Int    @map("meses_fixos")
  spread      Float
  euribor     Float
  dataInicio  String @map("data_inicio")
  bonificacaoMensal Float? @map("bonificacao_mensal")
  bonificacaoMeses  Int?   @map("bonificacao_meses")
  taeg              Float?
  euriborTenor      String? @map("euribor_tenor")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      LoanPayment[]
  amortizations LoanAmortization[]
  euriborHistory EuriborHistory[]

  @@map("loans")
}

model LoanPayment {
  id     String  @id @default(uuid())
  loanId String  @map("loan_id")
  ym     String
  paid   Boolean @default(false)
  real   Float?

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, ym])
  @@map("loan_payments")
}

model LoanAmortization {
  id     String @id @default(uuid())
  loanId String @map("loan_id")
  ym     String
  valor  Float
  modo   String

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_amortizations")
}

model EuriborHistory {
  id     String @id @default(uuid())
  loanId String @map("loan_id")
  ym     String
  valor  Float

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, ym])
  @@map("euribor_history")
}

// Global Euribor market data (ECB monthly averages) — fetched by the daily
// cron, shared by all users. NOT user data → EXCLUDED from export/import.
model EuriborRate {
  id        String   @id @default(uuid())
  tenor     String
  month     String
  value     Float
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenor, month])
  @@map("euribor_rates")
}

// ── Portfolio ─────────────────────────────────────────────────────

model PortfolioAsset {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  name           String
  ticker         String
  isin           String?
  qty            Float
  invested       Float
  value          Float
  monthly        Float  @default(0)
  expectedReturn Float  @default(0.07) @map("expected_return")
  lastPriceEur   Float? @map("last_price_eur")
  // Origin: "manual" (hand-added/legacy) or a broker id ("trading212"). The
  // broker snapshot-reconcile only auto-closes broker-sourced holdings.
  source         String @default("manual")

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  flows PortfolioFlow[]

  @@map("portfolio_assets")
}

// Applied broker order ids → idempotent CSV re-import (skip already-applied orders).
model ImportedTxn {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  source     String   // "trading212"
  externalId String   @map("external_id")
  createdAt  DateTime @default(now()) @map("created_at")
  // Transaction details for the IRS capital-gains report (WS6). Nullable —
  // legacy rows are dedup-keys only; a re-import backfills them.
  side       String?
  isin       String?
  ticker     String?
  qty        Float?
  totalEur   Float?   @map("total_eur")
  ym         String?
  txnTime    String?  @map("txn_time")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, externalId])
  @@index([userId])
  @@map("imported_txns")
}

model PortfolioFlow {
  id      String @id @default(uuid())
  assetId String @map("asset_id")
  ym      String
  amount  Float

  asset PortfolioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("portfolio_flows")
}

model PortfolioSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  gInc   Int    @default(3)
  gFY    Int    @default(2)
  gH     Int    @default(20)
  watchlistSymbols String? @map("watchlist_symbols")
  // UI language preference: 'pt' | 'en'. Null = follow browser/device locale.
  language         String? @map("language")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolio_settings")
}
