// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for dev — zero-setup file-based DB. Swap to "postgresql" for prod
  // (the schema below is portable, but you'll need to re-run migrations).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  // Optional because Google-only users have no local password
  passwordHash String?  @map("password_hash")
  // Google "sub" claim (stable per-user identifier). Unique, optional.
  googleId     String?  @unique @map("google_id")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  loans             Loan[]
  portfolioAssets   PortfolioAsset[]
  portfolioSettings PortfolioSettings?
  incomes           Income[]
  expenses          Expense[]
  classificationRules ClassificationRule[]
  bankConnections   BankConnection[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// Learned merchant → classification rule. When the user classifies a "Por
// classificar" line, we store a rule keyed on the normalized merchant and
// auto-apply it to siblings and to future imports.
// A linked bank via GoCardless Bank Account Data (PSD2). One row per
// requisition; transactions sync into the same budget-import pipeline.
model BankConnection {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  requisitionId   String   @unique @map("requisition_id")
  institutionId   String   @map("institution_id")
  institutionName String   @map("institution_name")
  logo            String?
  status          String   @default("created") // created | linked | expired
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_connections")
}

model ClassificationRule {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  matchKey  String   @map("match_key")  // normalized merchant name
  kind      String                       // 'income' | 'expense'
  type      String                       // 'fixed' | 'variable'
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchKey])
  @@index([userId])
  @@map("classification_rules")
}

// ── Budget ───────────────────────────────────────────────────────
model Income {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String                          // e.g. "Salário", "Freelance"
  amount    Float                           // EUR per month
  type      String   @default("fixed")      // 'fixed' | 'variable'
  category  String?                         // free-text bucket
  active    Boolean  @default(true)
  pending   Boolean  @default(false)        // true = imported, awaiting fixed/variable classification
  dayOfMonth Int?    @map("day_of_month")    // 1-31, set on statement import
  source    String?                          // origin: "Banco CTT", "Millennium BCP", null = manual
  startYm   String?  @map("start_ym")       // "AAAA-MM" — when it started
  endYm     String?  @map("end_ym")         // "AAAA-MM" — null = ongoing
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("incomes")
}

model Expense {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String                        // e.g. "Renda", "Netflix", "Comida"
  amount      Float                         // EUR per month (planned/typical)
  // 'fixed'    → predictable recurring (rent, subscriptions)
  // 'variable' → fluctuates monthly (food, entertainment)
  type        String                        // 'fixed' | 'variable'
  category    String?
  dayOfMonth  Int?     @map("day_of_month") // 1-31, optional
  active      Boolean  @default(true)
  pending     Boolean  @default(false)       // true = imported, awaiting fixed/variable classification
  source      String?                         // origin bank/import label; null = manual
  startYm     String?  @map("start_ym")
  endYm       String?  @map("end_ym")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@map("expenses")
}

// ── Loan ─────────────────────────────────────────────────────────

model Loan {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  name        String @default("Crédito")  // e.g. "Casa", "Carro"
  capital     Float
  prazoMeses  Int    @map("prazo_meses")
  tanFixa     Float  @map("tan_fixa")
  mesesFixos  Int    @map("meses_fixos")
  spread      Float
  euribor     Float
  dataInicio  String @map("data_inicio") // "AAAA-MM"
  // Optional spread rebate (e.g. Montepio "devolução de spread"):
  // the bank charges the full PMT but returns this amount each month.
  bonificacaoMensal Float? @map("bonificacao_mensal")
  bonificacaoMeses  Int?   @map("bonificacao_meses")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      LoanPayment[]
  amortizations LoanAmortization[]
  euriborHistory EuriborHistory[]

  @@map("loans")
}

model LoanPayment {
  id     String  @id @default(uuid())
  loanId String  @map("loan_id")
  ym     String  // "AAAA-MM"
  paid   Boolean @default(false)
  real   Float?  // actual amount paid (may differ from scheduled)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, ym])
  @@map("loan_payments")
}

model LoanAmortization {
  id     String @id @default(uuid())
  loanId String @map("loan_id")
  ym     String // "AAAA-MM"
  valor  Float
  // Allowed: 'prazo' | 'prestacao'. Stored as text because SQLite has no
  // native enum support — validated at the application layer.
  modo   String

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_amortizations")
}

model EuriborHistory {
  id     String @id @default(uuid())
  loanId String @map("loan_id")
  ym     String // "AAAA-MM"
  valor  Float

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, ym])
  @@map("euribor_history")
}

// ── Portfolio ─────────────────────────────────────────────────────

model PortfolioAsset {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  name           String
  ticker         String
  qty            Float
  invested       Float
  value          Float
  monthly        Float  @default(0) // monthly contribution (field `m`)
  expectedReturn Float  @default(0.07) @map("expected_return") // annual return % as fraction
  // EUR price per share at the last value refresh. Lets "Atualizar valores"
  // move `value` by the market's price change instead of recomputing qty*price
  // (qty is often an unreliable placeholder). Null until first refresh.
  lastPriceEur   Float? @map("last_price_eur")

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  flows PortfolioFlow[]

  @@map("portfolio_assets")
}

model PortfolioFlow {
  id      String @id @default(uuid())
  assetId String @map("asset_id")
  ym      String // "AAAA-MM"
  amount  Float

  asset PortfolioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("portfolio_flows")
}

model PortfolioSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  gInc   Int    @default(3)  // annual contribution increase %
  gFY    Int    @default(2)  // years without increase
  gH     Int    @default(20) // projection horizon in years
  // Comma-separated list of watchlist tickers, e.g. "NVDA,AAPL,MSFT".
  // Null/empty = use the app default. Length is enforced by the route.
  watchlistSymbols String? @map("watchlist_symbols")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolio_settings")
}
