// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for dev — zero-setup file-based DB. Swap to "postgresql" for prod
  // (the schema below is portable, but you'll need to re-run migrations).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  // Optional because Google-only users have no local password
  passwordHash String?  @map("password_hash")
  // Google "sub" claim (stable per-user identifier). Unique, optional.
  googleId     String?  @unique @map("google_id")
  // bcrypt hash of the 6-digit app-lock PIN. Null = no PIN set (app-lock off).
  pinHash      String?  @map("pin_hash")
  // Throwaway demo account (seeded sandbox). GC'd ~24h after createdAt.
  isDemo       Boolean  @default(false) @map("is_demo")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  loans             Loan[]
  portfolioAssets   PortfolioAsset[]
  portfolioSettings PortfolioSettings?
  incomes           Income[]
  expenses          Expense[]
  classificationRules ClassificationRule[]
  bankConnections   BankConnection[]
  brokerConnections BrokerConnection[]
  passwordResetTokens PasswordResetToken[]
  webauthnCredentials WebAuthnCredential[]
  importedTxns      ImportedTxn[]
  pushSubscriptions PushSubscription[]
  notificationPreference NotificationPreference?
  householdMember   HouseholdMember?

  @@map("users")
}

// ── Modo Casal (household v1) ────────────────────────────────────
// Two members max, ONE household per user, AGGREGATE-level sharing only (the
// overview endpoint exposes names + numbers, never line items). All three
// tables are EXCLUDED from export/import — cross-user data cannot be restored
// into a single-user backup. A household whose last member leaves is deleted
// in code (routes/household.ts).
model Household {
  id        String            @id @default(uuid())
  name      String            @default("A nossa casa")
  createdAt DateTime          @default(now()) @map("created_at")

  members HouseholdMember[]
  invites HouseholdInvite[]

  @@map("households")
}

model HouseholdMember {
  id          String   @id @default(uuid())
  householdId String   @map("household_id")
  userId      String   @unique @map("user_id") // one household per user (v1)
  joinedAt    DateTime @default(now()) @map("joined_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("household_members")
}

// Invite links: sha256 of the raw token (like PasswordResetToken), 7-day
// expiry, single-use, max 3 unused per household (spam guard in code).
model HouseholdInvite {
  id          String   @id @default(uuid())
  householdId String   @map("household_id")
  tokenHash   String   @unique @map("token_hash")
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("household_invites")
}

// One row per browser/device push registration. Device-bound (like passkeys)
// → deliberately EXCLUDED from export/import; dies with the user (cascade).
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// Per-user notification switches (push topics + the monthly email digest).
// Real user data → included in export/import. Digest is opt-OUT by design.
model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique @map("user_id")
  pushPayment        Boolean @default(true)  @map("push_payment")
  pushEuribor        Boolean @default(true)  @map("push_euribor")
  pushImportReminder Boolean @default(true)  @map("push_import_reminder")
  emailMonthlyDigest Boolean @default(true)  @map("email_monthly_digest")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// Append-only audit trail of account deletions. Deliberately NOT linked to User
// (it must survive the user's deletion) and holds NO personal data — only a
// one-way sha256 of the email so a deletion can later be verified without
// retaining PII. NOT part of per-user export/import (it isn't user-scoped data).
model DeletionLog {
  id        String   @id @default(uuid())
  emailHash String   @map("email_hash")
  method    String   @default("self-service") // how the deletion was initiated
  note      String?
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("deletion_log")
}

// A connected brokerage (e.g. Trading 212) for live portfolio sync. The API
// key/secret are stored ENCRYPTED (AES-256-GCM via lib/crypto.ts) — never in
// plaintext. Deliberately EXCLUDED from export/import backup (secrets are
// account+origin-bound and must not travel), like WebAuthnCredential.
model BrokerConnection {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  broker     String    // "trading212"
  env        String    @default("live") // "live" | "demo" (practice)
  keyEnc     String    @map("key_enc")
  secretEnc  String?   @map("secret_enc")
  accountCcy String?   @map("account_ccy")  // account currency reported on connect
  lastSyncAt DateTime? @map("last_sync_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, broker])
  @@index([userId])
  @@map("broker_connections")
}

// A registered WebAuthn (passkey/biometric) credential for the PIN lock's
// biometric unlock. One row per device+browser. Device-bound — deliberately NOT
// included in export/import backup (a credential is invalid outside its origin).
model WebAuthnCredential {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  credentialId String   @unique @map("credential_id") // base64url
  publicKey    String   @map("public_key")            // base64url-encoded COSE key
  counter      Int      @default(0)
  transports   String?                                 // CSV of authenticator transports
  deviceName   String?  @map("device_name")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webauthn_credentials")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// Learned merchant → classification rule. When the user classifies a "Por
// classificar" line, we store a rule keyed on the normalized merchant and
// auto-apply it to siblings and to future imports.
// A linked bank via GoCardless Bank Account Data (PSD2). One row per
// requisition; transactions sync into the same budget-import pipeline.
model BankConnection {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  requisitionId   String   @unique @map("requisition_id")
  institutionId   String   @map("institution_id")
  institutionName String   @map("institution_name")
  logo            String?
  status          String   @default("created") // created | linked | expired
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_connections")
}

model ClassificationRule {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  matchKey  String   @map("match_key")  // normalized merchant name
  kind      String                       // 'income' | 'expense'
  type      String                       // 'fixed' | 'variable'
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchKey])
  @@index([userId])
  @@map("classification_rules")
}

// ── Budget ───────────────────────────────────────────────────────
model Income {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String                          // e.g. "Salário", "Freelance"
  amount    Float                           // EUR per month (the MONTHLY-equivalent)
  // Entry cadence: monthly|weekly|biweekly|quarterly|annual. `amount` is always
  // stored as the monthly-equivalent; frequency only records how it was entered
  // (so a €2400/yr bonus saves amount=200, frequency=annual) and drives display.
  frequency String   @default("monthly")
  type      String   @default("fixed")      // 'fixed' | 'variable'
  category  String?                         // free-text bucket
  active    Boolean  @default(true)
  pending   Boolean  @default(false)        // true = imported, awaiting fixed/variable classification
  dayOfMonth Int?    @map("day_of_month")    // 1-31, set on statement import
  source    String?                          // origin: "Banco CTT", "Millennium BCP", null = manual
  // Optional bank-statement description for this fixed income. Imports whose
  // merchant normalizes to this (or to `name`) are matched to this plan row, so a
  // salary line like "ORDENADO ACME" links to an income you named "Salário".
  // Symmetric with Expense.matchHint — see merchantKey matching in routes/budget.ts.
  matchHint String?  @map("match_hint")
  startYm   String?  @map("start_ym")       // "AAAA-MM" — when it started
  endYm     String?  @map("end_ym")         // "AAAA-MM" — null = ongoing
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("incomes")
}

model Expense {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String                        // e.g. "Renda", "Netflix", "Comida"
  amount      Float                         // EUR per month (the monthly-equivalent)
  frequency   String   @default("monthly")  // monthly|weekly|biweekly|quarterly|annual (see Income.frequency)
  // 'fixed'    → predictable recurring (rent, subscriptions)
  // 'variable' → fluctuates monthly (food, entertainment)
  type        String                        // 'fixed' | 'variable'
  category    String?
  dayOfMonth  Int?     @map("day_of_month") // 1-31, optional
  active      Boolean  @default(true)
  pending     Boolean  @default(false)       // true = imported, awaiting fixed/variable classification
  source      String?                         // origin bank/import label; null = manual
  // Soft link to a Loan (mortgage/credit). When set, the budget shows this fixed
  // expense's amount LIVE from the loan's current prestação (see budget GET), so
  // the prestação isn't tracked in two places. Soft (no FK) — an unresolved id is
  // simply ignored, so deleting the loan just unlinks gracefully.
  loanId      String?  @map("loan_id")
  // Optional bank-statement description for this fixed expense. Imports whose
  // merchant normalizes to this (or to `name`) are matched to this plan row, so a
  // mortgage line like "EMP HABITACAO 0001" links to an expense you named
  // "Prestação casa". See merchantKey matching in routes/budget.ts.
  matchHint   String?  @map("match_hint")
  startYm     String?  @map("start_ym")
  endYm       String?  @map("end_ym")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@map("expenses")
}

// ── Loan ─────────────────────────────────────────────────────────

model Loan {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  name        String @default("Crédito")  // e.g. "Casa", "Carro"
  capital     Float
  prazoMeses  Int    @map("prazo_meses")
  tanFixa     Float  @map("tan_fixa")
  mesesFixos  Int    @map("meses_fixos")
  spread      Float
  euribor     Float
  dataInicio  String @map("data_inicio") // "AAAA-MM"
  // Optional spread rebate (e.g. Montepio "devolução de spread"):
  // the bank charges the full PMT but returns this amount each month.
  bonificacaoMensal Float? @map("bonificacao_mensal")
  bonificacaoMeses  Int?   @map("bonificacao_meses")
  taeg              Float? // display-only TAEG for fixed-rate loans (e.g. car, personal)
  // Which Euribor tenor the contract revises on: "3m" | "6m" | "12m".
  // null = manual mode (no auto-tracking / revision projection) — the default.
  euriborTenor      String? @map("euribor_tenor")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      LoanPayment[]
  amortizations LoanAmortization[]
  euriborHistory EuriborHistory[]

  @@map("loans")
}

model LoanPayment {
  id     String  @id @default(uuid())
  loanId String  @map("loan_id")
  ym     String  // "AAAA-MM"
  paid   Boolean @default(false)
  real   Float?  // actual amount paid (may differ from scheduled)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, ym])
  @@map("loan_payments")
}

model LoanAmortization {
  id     String @id @default(uuid())
  loanId String @map("loan_id")
  ym     String // "AAAA-MM"
  valor  Float
  // Allowed: 'prazo' | 'prestacao'. Stored as text because SQLite has no
  // native enum support — validated at the application layer.
  modo   String

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_amortizations")
}

model EuriborHistory {
  id     String @id @default(uuid())
  loanId String @map("loan_id")
  ym     String // "AAAA-MM"
  valor  Float

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, ym])
  @@map("euribor_history")
}

// Global Euribor market data (monthly averages from the ECB Data Portal) —
// fetched by the daily cron, shared by all users. PT mortgage revisions use
// the PREVIOUS month's monthly average, which is exactly this series.
// NOT user data → deliberately EXCLUDED from export.ts / import.ts.
model EuriborRate {
  id        String   @id @default(uuid())
  tenor     String   // "3m" | "6m" | "12m"
  month     String   // "AAAA-MM" — the month the average covers
  value     Float    // percent, e.g. 2.5955 (divide by 100 before the loan engine)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenor, month])
  @@map("euribor_rates")
}

// ── Portfolio ─────────────────────────────────────────────────────

model PortfolioAsset {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  name           String
  ticker         String
  // ISIN — the stable cross-broker identity (e.g. from a Trading212 import).
  // The Yahoo `ticker` can drift/ambiguate across exchanges; the ISIN doesn't.
  // Used to dedupe re-imports and (later) to map broker holdings to Yahoo symbols.
  isin           String?
  qty            Float
  invested       Float
  value          Float
  monthly        Float  @default(0) // monthly contribution (field `m`)
  expectedReturn Float  @default(0.07) @map("expected_return") // annual return % as fraction
  // EUR price per share at the last value refresh. Lets "Atualizar valores"
  // move `value` by the market's price change instead of recomputing qty*price
  // (qty is often an unreliable placeholder). Null until first refresh.
  lastPriceEur   Float? @map("last_price_eur")
  // Origin of the holding: "manual" (hand-added/legacy) or a broker id
  // ("trading212"). The broker snapshot-reconcile only auto-closes holdings
  // whose source is the broker — manual holdings are never auto-removed.
  source         String @default("manual")

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  flows PortfolioFlow[]

  @@map("portfolio_assets")
}

// Records each broker transaction (by its external order ID) that has already
// been applied to the portfolio, so re-importing a Trading 212 CSV is
// idempotent — orders already applied are skipped instead of double-counted.
model ImportedTxn {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  source     String   // "trading212"
  externalId String   @map("external_id") // broker order id, e.g. EOF53208567774
  createdAt  DateTime @default(now()) @map("created_at")
  // Transaction details for the IRS capital-gains report (WS6). Nullable:
  // rows created before 2026-07 are dedup-keys only — re-importing the same
  // CSV BACKFILLS them (update where side is null) without re-applying.
  side       String?  // "buy" | "sell"
  isin       String?
  ticker     String?
  qty        Float?
  totalEur   Float?   @map("total_eur") // EUR total of the order
  ym         String?  // "AAAA-MM" (Anexo J is year+month granular)
  txnTime    String?  @map("txn_time")  // raw broker timestamp — FIFO ordering

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, externalId])
  @@index([userId])
  @@map("imported_txns")
}

model PortfolioFlow {
  id      String @id @default(uuid())
  assetId String @map("asset_id")
  ym      String // "AAAA-MM"
  amount  Float

  asset PortfolioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("portfolio_flows")
}

model PortfolioSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  gInc   Int    @default(3)  // annual contribution increase %
  gFY    Int    @default(2)  // years without increase
  gH     Int    @default(20) // projection horizon in years
  // Comma-separated list of watchlist tickers, e.g. "NVDA,AAPL,MSFT".
  // Null/empty = use the app default. Length is enforced by the route.
  watchlistSymbols String? @map("watchlist_symbols")
  // UI language preference: 'pt' | 'en'. Null = follow browser/device locale.
  language         String? @map("language")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolio_settings")
}
