# SQLite for dev (file ends up at backend/prisma/dev.db)
DATABASE_URL="file:./dev.db"

# For production, swap to: postgresql://user:pass@host:5432/wallet_app
# DATABASE_URL="postgresql://postgres:password@localhost:5432/wallet_app"

SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Finnhub API key (never expose to the browser)
FINNHUB_API_KEY=""

# Google Sign In — OAuth 2.0 Web Client ID from Google Cloud Console
# (e.g. 123456789-abcdef.apps.googleusercontent.com)
# Without this, the "Sign in with Google" button stays hidden in the UI.
GOOGLE_CLIENT_ID=""

PORT=4000
NODE_ENV=development
